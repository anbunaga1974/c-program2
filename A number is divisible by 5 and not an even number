#include<stdio.h>
int main()
{
        int n;
        printf("Enter a number:");
        scanf("%d",&n);
        if (n%5==0 && n%2!=0)
                printf("Number is divisible by 5 and not an even number");
        else if(n%5==0 && n%2==0)
                printf("Number is divisible by 5 and an even number");
        else if(n%5!=0 && n%2==0)
                printf("Number is not divisible by 5 and an even number");
        else if(n%5!=0 && n%2!=0)
                printf("Number is not divisible by 5 and not an even number");
        else
                printf("Number is invalid");
        return 0;
}
