#include<stdio.h>
int main()
{
        int A,B,C;
        printf("Enter A:");
        scanf("%d",&A);
        printf("Enter B:");
        scanf("%d",&B);
        printf("Enter C:");
        scanf("%d",&C);
        if(A>B && A>C)
                printf("A is greater");
        else if(B>C)
                printf("B is greater");
        else
                printf("C is greater");
        printf("\nEnd");
        return 0;
}
