#include<stdio.h>
int main()
{
        int choice,a,b;
        printf("1. Addition");
        printf("\n2. Subtraction");
        printf("\n3. Multiplication");
        printf("\n4. Division");
        printf("\n5. Modulo");
        printf("\nEnter your choice:");
        scanf("%d",&choice);
        printf("Enter 1st number:");
        scanf("%d",&a);
        printf("Enter 2nd number:");
        scanf("%d",&b);
        switch(choice)
        {
                case 1:
                        printf("Addition result:%d",a+b);
                        break;
                case 2:
                        printf("Subtraction result:%d",a-b);
                        break;
                case 3:
                        printf("Multiplication result:%d",a*b);
                        break;
                case 4:
                        if(b!=0)
                                printf("Division result:%d",a/b);
                        else
                                printf("b should not be zero");
                        break;
                case 5:
                        printf("Modulo result:%d",a%b);
                        break;
                default:
                        printf("Invalid choice");
        }
        printf("\nFinished");
        return 0;
}
